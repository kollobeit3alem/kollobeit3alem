<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | كله بيتعلم</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* تعريف الخط الخاص بالمنصة */
        @font-face {
            font-family: 'AbdoLogo';
            src: url('alfont_com_Abdo.Fonts_Abdo.Logo_.ttf') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        :root {
            --primary: #015669; 
            --primary-light: rgba(1, 86, 105, 0.1);
            --bg-page: #f4f7f9;
            --white: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --radius: 20px;
            --danger: #ef4444;
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'AbdoLogo', sans-serif !important;
        }

        body {
            background-color: var(--bg-page);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- تصميم القائمة الجانبية (Sidebar) --- */
        .sidebar {
            width: 280px;
            background-color: var(--white);
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            box-shadow: -5px 0 30px rgba(0,0,0,0.02);
            z-index: 10;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        .brand img {
            width: 50px;
            border-radius: 12px;
        }

        .brand h2 {
            color: var(--primary);
            font-size: 22px;
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex: 1;
        }

        .nav-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            text-align: right;
            padding: 15px 20px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s ease;
        }

        .nav-btn i {
            font-size: 20px;
            width: 25px;
            text-align: center;
        }

        .nav-btn:hover {
            background: var(--bg-page);
            color: var(--primary);
            transform: translateX(-5px);
        }

        .nav-btn.active {
            background: var(--primary);
            color: var(--white);
            box-shadow: 0 10px 20px var(--primary-light);
        }

        .logout-btn {
            margin-top: auto;
            background: #fff1f2;
            color: var(--danger);
        }
        .logout-btn:hover {
            background: var(--danger);
            color: white;
        }

        /* --- تصميم منطقة المحتوى (Main Content) --- */
        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
        }

        .header-title {
            font-size: 28px;
            color: var(--primary);
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- تصميم البطاقات والنماذج --- */
        .card {
            background: var(--white);
            padding: 30px;
            border-radius: var(--radius);
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            margin-bottom: 30px;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .card h3 {
            color: var(--primary);
            margin-bottom: 25px;
            font-size: 20px;
            border-right: 4px solid var(--primary);
            padding-right: 10px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
            grid-column: span 1;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: var(--text-main);
        }

        input, textarea, select {
            width: 100%;
            padding: 15px;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            font-size: 15px;
            color: var(--text-main);
            background: var(--bg-page);
            transition: border-color 0.3s;
        }

        input:focus, textarea:focus, select:focus {
            border-color: var(--primary);
            outline: none;
            background: var(--white);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
        }

        .btn-submit {
            background: var(--primary);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            box-shadow: 0 5px 15px var(--primary-light);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px var(--primary-light);
        }

        /* --- تصميم القوائم (Grids) --- */
        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .item-card {
            background: var(--bg-page);
            padding: 20px;
            border-radius: 16px;
            border: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 15px;
            transition: transform 0.3s;
        }

        .item-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
        }

        .item-card-title {
            font-size: 18px;
            font-weight: bold;
            color: var(--primary);
        }

        .item-actions {
            display: flex;
            gap: 10px;
            margin-top: auto;
        }

        .btn-action {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-delete { background: #fee2e2; color: var(--danger); }
        .btn-delete:hover { background: var(--danger); color: white; }
        
        .btn-edit { background: #e0f2fe; color: #0284c7; }
        .btn-edit:hover { background: #0284c7; color: white; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="brand">
            <img src="كله بيتعلم (1).png" alt="Logo">
            <h2>الإدارة المركزية</h2>
        </div>
        
        <nav class="nav-menu">
            <button class="nav-btn active" onclick="switchTab('courses', this)">
                <i class="fas fa-layer-group"></i> إدارة الدورات
            </button>
            <button class="nav-btn" onclick="switchTab('lessons', this)">
                <i class="fas fa-video"></i> إدارة المحاضرات
            </button>
            <button class="nav-btn" onclick="switchTab('quizzes', this)">
                <i class="fas fa-spell-check"></i> الامتحانات
            </button>
            <button class="nav-btn" onclick="switchTab('users', this)">
                <i class="fas fa-users-cog"></i> المدرسين والطلاب
            </button>
            
            <button class="nav-btn logout-btn" onclick="logout()">
                <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
            </button>
        </nav>
    </aside>

    <main class="main-content">

        <section id="courses-tab" class="tab-content active">
            <h1 class="header-title"><i class="fas fa-layer-group"></i> إدارة الدورات التدريبية</h1>
            
            <div class="card">
                <h3><i class="fas fa-plus-circle"></i> إضافة دورة جديدة</h3>
                <form id="course-form" class="form-grid">
                    <div class="form-group full-width">
                        <label>عنوان الدورة</label>
                        <input type="text" id="c-title" placeholder="مثال: كورس المونتاج الاحترافي" required>
                    </div>
                    <div class="form-group full-width">
                        <label>وصف الدورة</label>
                        <textarea id="c-desc" placeholder="اكتب وصفاً موجزاً لما سيتعلمه الطالب..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>رابط صورة الغلاف</label>
                        <input type="url" id="c-img" placeholder="https://..." required>
                    </div>
                    <div class="form-group">
                        <label>رابط تواصل المدرس (اختياري)</label>
                        <input type="url" id="c-contact" placeholder="رابط تليجرام أو واتساب">
                    </div>
                    <div class="form-group full-width">
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-save"></i> حفظ ونشر الدورة
                        </button>
                    </div>
                </form>
            </div>

            <div class="card">
                <h3><i class="fas fa-list"></i> الدورات المتاحة حالياً</h3>
                <div class="items-grid" id="courses-list">
                    </div>
            </div>
        </section>

        <section id="lessons-tab" class="tab-content">
            <h1 class="header-title"><i class="fas fa-video"></i> إدارة المحاضرات</h1>
            
            <div class="card">
                <h3><i class="fas fa-plus-circle"></i> إضافة محاضرة لدورة</h3>
                <form id="lesson-form" class="form-grid">
                    <div class="form-group full-width">
                        <label>اختر الدورة</label>
                        <select id="l-course-id" required>
                            <option value="">جاري تحميل الدورات...</option>
                        </select>
                    </div>
                    <div class="form-group full-width">
                        <label>عنوان المحاضرة</label>
                        <input type="text" id="l-title" required>
                    </div>
                    <div class="form-group">
                        <label>رابط الفيديو (YouTube)</label>
                        <input type="url" id="l-url" required>
                    </div>
                    <div class="form-group">
                        <label>ترتيب المحاضرة (رقم)</label>
                        <input type="number" id="l-order" value="1" required>
                    </div>
                    <div class="form-group full-width">
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-upload"></i> رفع المحاضرة
                        </button>
                    </div>
                </form>
            </div>
        </section>

        <section id="quizzes-tab" class="tab-content">
            <h1 class="header-title"><i class="fas fa-spell-check"></i> الامتحانات المصورة</h1>
            
            <div class="card">
                <h3><i class="fas fa-file-signature"></i> إضافة سؤال لمحاضرة</h3>
                <form id="quiz-form" class="form-grid">
                    <div class="form-group full-width">
                        <label>المحاضرة المرتبطة بالامتحان</label>
                        <select id="q-lesson-id"><option>سيتم تفعيل هذه القائمة قريباً</option></select>
                    </div>
                    <div class="form-group full-width">
                        <label>رابط صورة السؤال</label>
                        <input type="url" id="q-img" placeholder="ارفع صورة السؤال وضع الرابط هنا">
                    </div>
                    <div class="form-group"><label>خيار (أ)</label><input type="text" id="q-opt-a"></div>
                    <div class="form-group"><label>خيار (ب)</label><input type="text" id="q-opt-b"></div>
                    <div class="form-group"><label>خيار (ج)</label><input type="text" id="q-opt-c"></div>
                    <div class="form-group"><label>خيار (د)</label><input type="text" id="q-opt-d"></div>
                    
                    <div class="form-group full-width">
                        <label>الإجابة الصحيحة</label>
                        <select id="q-correct">
                            <option value="A">أ</option>
                            <option value="B">ب</option>
                            <option value="C">ج</option>
                            <option value="D">د</option>
                        </select>
                    </div>
                    <div class="form-group full-width">
                        <button type="button" class="btn-submit"><i class="fas fa-check-circle"></i> حفظ الامتحان</button>
                    </div>
                </form>
            </div>
        </section>

        <section id="users-tab" class="tab-content">
            <h1 class="header-title"><i class="fas fa-users-cog"></i> إدارة الصلاحيات</h1>
            <div class="card">
                <h3>ترقية مستخدم إلى مدرس</h3>
                <p style="color: var(--text-muted); margin-bottom: 20px;">أدخل البريد الإلكتروني للطالب لتحويله إلى (مدرس) ليتمكن من الدخول للوحة التحكم.</p>
                <div class="form-group">
                    <input type="email" placeholder="example@gmail.com">
                </div>
                <button type="button" class="btn-submit"><i class="fas fa-user-graduate"></i> ترقية الحساب</button>
            </div>
        </section>

    </main>

    <script>
        const workerBaseUrl = 'https://kollobeit3alem.pages.dev';
        
        // جلب التوكن للمصادقة مع السيرفر
        function getToken() {
            return localStorage.getItem('auth_token');
        }

        // التحقق من تسجيل الدخول
        document.addEventListener('DOMContentLoaded', () => {
            if (!getToken()) {
                window.location.href = '/';
            }
            loadCourses();
        });

        // دالة التنقل بين التبويبات
        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            
            document.getElementById(tabId + '-tab').classList.add('active');
            btn.classList.add('active');
        }

        // تسجيل الخروج
        function logout() {
            localStorage.clear();
            window.location.href = '/';
        }

        // ==========================================
        // العمليات البرمجية (API Calls)
        // ==========================================

        // 1. جلب الكورسات وعرضها
        async function loadCourses() {
            try {
                const response = await fetch(`${workerBaseUrl}/api/courses`);
                const courses = await response.json();
                
                const list = document.getElementById('courses-list');
                const select = document.getElementById('l-course-id');
                
                list.innerHTML = '';
                select.innerHTML = '<option value="">اختر الدورة...</option>';

                courses.forEach(c => {
                    // عرض الكورس في القائمة
                    list.innerHTML += `
                        <div class="item-card">
                            <div class="item-card-title">${c.title}</div>
                            <div style="font-size:13px; color:var(--text-muted)">
                                <i class="fas fa-clock"></i> تم الإنشاء: ${new Date(c.created_at).toLocaleDateString('ar-EG')}
                            </div>
                            <div class="item-actions">
                                <button class="btn-action btn-delete" onclick="deleteCourse(${c.id})">
                                    <i class="fas fa-trash"></i> حذف
                                </button>
                            </div>
                        </div>
                    `;
                    // إضافته في قائمة الاختيار لإضافة درس
                    select.innerHTML += `<option value="${c.id}">${c.title}</option>`;
                });
            } catch (error) {
                console.error("Error loading courses:", error);
            }
        }

        // 2. إضافة كورس جديد
        document.getElementById('course-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
            btn.disabled = true;

            const data = {
                title: document.getElementById('c-title').value,
                description: document.getElementById('c-desc').value,
                image_url: document.getElementById('c-img').value,
                instructor_contact: document.getElementById('c-contact').value
            };

            try {
                const response = await fetch(`${workerBaseUrl}/api/admin/courses`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${getToken()}`
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    alert('تم إضافة الدورة بنجاح!');
                    e.target.reset();
                    loadCourses();
                } else {
                    alert('فشلت العملية. تأكد من صلاحياتك.');
                }
            } catch (error) {
                alert('حدث خطأ في الاتصال');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });

        // 3. حذف كورس
        async function deleteCourse(id) {
            if (!confirm('هل أنت متأكد من حذف هذه الدورة بالكامل بجميع دروسها؟')) return;

            try {
                const response = await fetch(`${workerBaseUrl}/api/admin/courses/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${getToken()}` }
                });

                if (response.ok) {
                    loadCourses();
                } else {
                    alert('فشل الحذف. راجع الصلاحيات.');
                }
            } catch (error) {
                alert('خطأ في الاتصال');
            }
        }

        // 4. إضافة درس لكورس
        document.getElementById('lesson-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الرفع...';
            btn.disabled = true;

            const data = {
                course_id: document.getElementById('l-course-id').value,
                title: document.getElementById('l-title').value,
                video_url: document.getElementById('l-url').value,
                order_num: document.getElementById('l-order').value
            };

            try {
                const response = await fetch(`${workerBaseUrl}/api/admin/lessons`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${getToken()}`
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    alert('تم إضافة المحاضرة بنجاح!');
                    document.getElementById('l-title').value = '';
                    document.getElementById('l-url').value = '';
                    document.getElementById('l-order').value = parseInt(data.order_num) + 1;
                } else {
                    alert('فشلت الإضافة.');
                }
            } catch (error) {
                alert('خطأ في الاتصال');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
